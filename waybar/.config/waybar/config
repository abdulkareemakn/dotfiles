[
  {
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 5,
    "modules-left": [
      "hyprland/workspaces",
      "custom/separator",
      "hyprland/window"
    ],
    "modules-center": [
      "sway/window"
    ],
    "modules-right": [
      "mpd",
      "idle_inhibitor",
      "temperature",
      "cpu",
      "memory",
      "network",
      "bluetooth",
      "wireplumber",
      "backlight",
      "keyboard-state",
      "battery",
      "battery#bat2",
      "tray",
      "clock"
    ],
    "hyprland/workspaces": {
      "active-only": true
    },
    "hyprland/window": {
      "format": "{class}",
      "max-length": 20,
      "rewrite": {
        "^(?!.*\\S).*": "Finder"
      }
    },
    "custom/separator": {
      "format": "|",
      "tooltip": false
    },
    "custom/launcher": {
      "format": "ЁЯФН",
      "on-click": "wofi --show drun",
      "tooltip": false
    },
    "custom/texttwo": {
      "exec": "echo 'File'",
      "interval": 60,
      "return-type": "plain",
      "on-click": "nautilus"
    },
    "custom/textthree": {
      "exec": "echo 'Edit'",
      "interval": 60,
      "return-type": "plain",
      "on-click": "gimp"
    },
    "custom/textfour": {
      "exec": "echo 'View'",
      "interval": 60,
      "return-type": "plain"
    },
    "custom/textfive": {
      "exec": "echo 'Help'",
      "interval": 60,
      "return-type": "plain",
      "on-click": "gio open https://github.com/kamlendras/waybar/issues/new"
    },
    "keyboard-state": {
      "numlock": true,
      "capslock": true,
      "format": "{name} {icon}",
      "format-icons": {
        "locked": "яАг",
        "unlocked": "яВЬ"
      }
    },
    "sway/mode": {
      "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
      "format": "{icon} {count}",
      "show-empty": false,
      "format-icons": [
        "",
        "яЛТ"
      ],
      "tooltip": true,
      "tooltip-format": "{app}: {title}"
    },
    "mpd": {
      "format": "яАБ  {title} - {artist} {stateIcon} [{elapsedTime:%M:%S}/{totalTime:%M:%S}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}[{songPosition}/{queueLength}] [{volume}%]",
      "format-disconnected": "яАБ Disconnected",
      "format-stopped": "яАБ {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
      "unknown-tag": "N/A",
      "interval": 2,
      "consume-icons": {
        "on": "яГД "
      },
      "random-icons": {
        "on": "яБ┤ "
      },
      "repeat-icons": {
        "on": "яАЮ "
      },
      "single-icons": {
        "on": "яАЮ1 "
      },
      "state-icons": {
        "paused": "яБМ",
        "playing": "яБЛ"
      },
      "tooltip-format": "MPD (connected)",
      "tooltip-format-disconnected": "MPD (disconnected)",
      "on-click": "mpc toggle",
      "on-click-right": "foot -a ncmpcpp ncmpcpp",
      "on-scroll-up": "mpc volume +2",
      "on-scroll-down": "mpc volume -2"
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "яБо",
        "deactivated": "яБ░"
      }
    },
    "tray": {
      "spacing": 10
    },
    "clock": {
      "format": "{:%A %B %d %H:%M %p}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
      "format": "яЛЫ  {usage}%"
    },
    "memory": {
      "format": "яГЙ {}%"
    },
    "temperature": {
      "thermal-zone": 2,
      "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
      "critical-threshold": 80,
      "format-critical": "{icon} {temperatureC}┬░C",
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": [
        "яЛЛ",
        "яЛЙ",
        "яЛЗ"
      ]
    },
    "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": [
        "юОН",
        "юПУ",
        "юПС",
        "юПП",
        "юПО",
        "юПН",
        "юПК",
        "юПИ",
        "юОЫ"
      ]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "яЗж {capacity}%",
      "format-plugged": "яЗж {capacity}%",
      "format-alt": "{icon} {time}",
      "format-icons": [
        "яЙД ",
        "яЙГ ",
        "яЙВ ",
        "яЙБ ",
        "яЙА "
      ]
    },
    "battery#bat2": {
      "bat": "BAT2"
    },
    "network": {
      "format-wifi": "яЗл ",
      "format-ethernet": "яЮЦ ",
      "format-linked": "ґ░Цк ",
      "format-disconnected": "ґ░Цк ",
      "tooltip-format-wifi": "{essid} - {ipaddr}",
      "tooltip-format-ethernet": "Ethernet - {ipaddr}",
      "tooltip-format-disconnected": "Disconnected",
      "on-click": "kitty --class wlctl -e wlctl"
    },
    "wireplumber": {
      "format": "{icon} {volume}%",
      "format-muted": "ю╗и ",
      "format-icons": ["яАж", "яАз ", "яАи  "],
      "on-click": "pavucontrol",
      "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
      "scroll-step": 5
    },
    "bluetooth": {
      "format": "яКФ",
      "format-disabled": "ґ░В▓ ",
      "format-connected": "ґ░В▒ ",
      "tooltip-format": "{controller_alias}\t{controller_address}",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "on-click": "kitty --class bluetui -e bluetui"
    },
    "pulseaudio": {
      "scroll-step": 5,
      "format": "{icon}  {volume}% {format_source}",
      "format-bluetooth": "яКФ {icon} {volume}% {format_source}",
      "format-bluetooth-muted": "яЪй яКФ {icon} {format_source}",
      "format-muted": "ю╗и   {format_source}",
      "format-source": "яД░ {volume}%",
      "format-source-muted": "яД▒",
      "format-icons": {
        "default": [
          "яАж",
          "яАз",
          "яАи"
        ]
      },
      "on-click": "pavucontrol",
      "on-click-right": "foot -a pw-top pw-top"
    }
  }
]
